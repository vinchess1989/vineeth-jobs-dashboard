rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthorized() {
      return request.auth != null && (
        request.auth.token.email == "vineethkaimal1989@gmail.com"
      );
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId && isAuthorized();
    }
    
    match /shared_state/{docId} {
      allow read, write: if isAuthorized();
    }
    
    match /user_feedback/{docId} {
      allow read, update: if true;
      allow create, delete: if isAuthorized();
    }
  }
}
